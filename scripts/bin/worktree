#!/usr/bin/env bash

# Git worktree manager - both interactive and CLI modes
# Usage:
#   worktree                         # Interactive UI
#   worktree add <branch>            # Add worktree
#   worktree add <branch> --base <b> # Add worktree from specific base branch
#   worktree remove <path>           # Remove worktree
#   worktree prune                   # Prune stale worktree entries
#   worktree list                    # List worktrees (for scripting)
#   worktree switch <branch>         # Connect to existing worktree by branch name
#   worktree switch -c <branch>      # Create worktree and connect

set -euo pipefail

usage() {
	cat <<EOF
Usage: worktree [COMMAND] [ARGS]

Commands:
    (no args)                  Open interactive worktree manager
    add <branch>               Create new worktree for branch
    add <branch> --base <b>    Create worktree from specific base branch
    remove <path>              Remove worktree at path (fails if dirty)
    remove <path> --force      Remove worktree discarding uncommitted changes
    prune                      Prune stale worktree admin entries
    list                       List worktrees (paths only, for scripting)
    switch <branch>            Connect to existing worktree by branch name
    switch -c <branch>         Create worktree and connect
    -h, --help                 Show this help

Examples:
    worktree
    worktree add feature-login
    worktree add feature-login --base develop
    worktree remove /path/to/worktree
    worktree list | xargs -I{} git -C {} status
    worktree switch feature-login
    worktree switch -c feature-login
EOF
}

check_git_repo() {
	git rev-parse --git-dir >/dev/null 2>&1
}

get_repo_root() {
	git worktree list | head -1 | awk '{print $1}'
}

prune_worktrees() {
	local repo_root
	repo_root=$(get_repo_root)
	local output
	output=$(git -C "$repo_root" worktree prune -v 2>&1)
	if [[ -n "$output" ]]; then
		echo "$output"
	else
		echo "Nothing to prune"
	fi
}

cleanup_after_remove() {
	git worktree prune >/dev/null 2>&1 || true
	git delete-squashed >/dev/null 2>&1 || true
	tmux-clean >/dev/null 2>&1 || true
}

add_worktree() {
	local branch_name="$1"
	local base_branch="${2:-}"

	if [[ -z "$branch_name" ]]; then
		echo "Error: Branch name cannot be empty"
		return 1
	fi

	# Validate branch name (no spaces or special chars except - _ /)
	if [[ ! "$branch_name" =~ ^[a-zA-Z0-9/_-]+$ ]]; then
		echo "Error: Invalid branch name '$branch_name' (use alphanumeric, -, _, /)"
		return 1
	fi

	local repo_root
	repo_root=$(get_repo_root)
	local repo_name
	repo_name=$(basename "$repo_root")
	local worktree_path="$(dirname "$repo_root")/$repo_name.$branch_name"

	if [[ -d "$worktree_path" ]]; then
		echo "Error: Worktree already exists at $worktree_path"
		return 1
	fi

	local output
	# Try to create worktree with new branch first
	if [[ -n "$base_branch" ]]; then
		if output=$(git worktree add -b "$branch_name" "$worktree_path" "$base_branch" 2>&1); then
			echo "Created worktree '$branch_name' at $worktree_path (from $base_branch)"
			return 0
		fi
	else
		if output=$(git worktree add -b "$branch_name" "$worktree_path" 2>&1); then
			echo "Created worktree '$branch_name' at $worktree_path"
			return 0
		fi
	fi

	# If branch exists, try using existing branch
	if output=$(git worktree add "$worktree_path" "$branch_name" 2>&1); then
		echo "Created worktree for existing branch '$branch_name' at $worktree_path"
		return 0
	fi

	# Show actual error
	echo "Error: Failed to create worktree '$branch_name'"
	echo "$output" | head -3
	return 1
}

remove_worktree() {
	local worktree_path="$1"
	local force="${2:-}"

	if [[ -z "$worktree_path" ]]; then
		echo "Error: Worktree path cannot be empty"
		return 1
	fi

	local repo_root
	repo_root=$(get_repo_root)

	# Warn if worktree has uncommitted changes and not forcing
	if [[ "$force" != "--force" ]] && [[ -d "$worktree_path" ]]; then
		local dirty
		dirty=$(git -C "$worktree_path" status --porcelain 2>/dev/null || true)
		if [[ -n "$dirty" ]]; then
			echo "Error: Worktree '$worktree_path' has uncommitted changes. Use --force to discard."
			return 1
		fi
	fi

	local output
	if output=$(git -C "$repo_root" worktree remove -f "$worktree_path" 2>&1); then
		echo "Removed worktree: $worktree_path"
		cleanup_after_remove
		return 0
	fi

	echo "Error: Failed to remove worktree '$worktree_path'"
	echo "$output" | head -3
	return 1
}

list_worktrees() {
	git worktree list --porcelain | awk '/^worktree / {print $2}'
}

list_worktrees_with_status() {
	local repo_root
	repo_root=$(get_repo_root)

	local -a paths hashes branches
	local wt_path="" wt_hash="" wt_branch=""
	while IFS= read -r line; do
		case "$line" in
		worktree\ *) wt_path="${line#worktree }" ;;
		HEAD\ *)     wt_hash="${line#HEAD }"; wt_hash="${wt_hash:0:7}" ;;
		branch\ *)   wt_branch="${line#branch refs/heads/}" ;;
		'')
			[[ -n "$wt_path" ]] && paths+=("$wt_path") && hashes+=("$wt_hash") && branches+=("$wt_branch")
			wt_path="" wt_hash="" wt_branch=""
			;;
		esac
	done < <(git -C "$repo_root" worktree list --porcelain)
	[[ -n "$wt_path" ]] && paths+=("$wt_path") && hashes+=("$wt_hash") && branches+=("$wt_branch")

	local max_len=0
	for p in "${paths[@]}"; do
		[[ ${#p} -gt $max_len ]] && max_len=${#p}
	done

	local tmpdir
	tmpdir=$(mktemp -d)

	for i in "${!paths[@]}"; do
		(
			local wt_path="${paths[$i]}" hash="${hashes[$i]}" branch="${branches[$i]}" indicators=""

			local dirty
			dirty=$(git -C "$wt_path" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
			[[ "$dirty" -gt 0 ]] && indicators+="\033[31m*\033[0m"

			if [[ -n "$branch" ]]; then
				local ref default_branch ahead behind
				ref=$(git -C "$wt_path" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null) \
					&& default_branch="${ref##refs/remotes/origin/}" || default_branch="main"
				ahead=$(git -C "$wt_path" rev-list --count "origin/$default_branch..$branch" 2>/dev/null || echo 0)
				behind=$(git -C "$wt_path" rev-list --count "$branch..origin/$default_branch" 2>/dev/null || echo 0)
				[[ "$ahead" -gt 0 ]] && indicators+="\033[33m↑${ahead}\033[0m"
				[[ "$behind" -gt 0 ]] && indicators+="\033[36m↓${behind}\033[0m"
			fi

			printf "%-${max_len}s\t\033[33m%s\033[0m  \033[32m[%s]\033[0m %b\n" \
				"$wt_path" "$hash" "${branch:-detached}" "$indicators"
		) >"$tmpdir/$i" &
	done
	wait

	for i in "${!paths[@]}"; do cat "$tmpdir/$i"; done
	rm -rf "$tmpdir"
}

switch_worktree() {
	local create=0
	local branch_name=""
	while [[ $# -gt 0 ]]; do
		case "$1" in
		-c)
			create=1
			shift
			;;
		*)
			branch_name="$1"
			shift
			;;
		esac
	done

	if [[ -z "$branch_name" ]]; then
		echo "Error: Branch name required"
		return 1
	fi

	if [[ "$create" -eq 1 ]]; then
		add_worktree "$branch_name" || return 1
	fi

	local match
	match=$(git worktree list --porcelain |
		awk '/^worktree / {path=$2} /^branch refs\/heads\// {branch=$2; sub("refs/heads/","",branch); if (branch=="'"$branch_name"'") print path}')

	if [[ -z "$match" ]]; then
		echo "Error: No worktree for branch '$branch_name'"
		return 1
	fi

	sesh connect "$match"
}

interactive_mode() {
	if ! check_git_repo; then
		return 1
	fi

	local repo_root
	repo_root=$(get_repo_root)

	local selected
	selected=$(worktree list-status | fzf \
		--ansi \
		--delimiter $'\t' \
		--border-label '🌴 Worktrees ' \
		--header 'CTRL-X (remove) : CTRL-A (add) : CTRL-G (prune) : ENTER (connect)' \
		--bind "ctrl-x:execute-silent(worktree remove {1} --force 2>/dev/null || true)+reload(worktree list-status)" \
		--bind "ctrl-a:transform:[[ -n {q} ]] && echo 'reload(worktree add {q} --base main >/dev/null; worktree list-status)' || echo 'bell'" \
		--bind "ctrl-g:execute-silent(worktree prune >/dev/null)+reload(worktree list-status)" \
		--preview "$(
			cat <<'PREVIEW'
			path={1}
			echo -e '\033[1;36m📍 Worktree:\033[0m '"$path"
			echo

			# Show branch with ahead/behind info
			branch=$(git -C "$path" branch --show-current 2>/dev/null)
			ref=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null) && default="${ref##refs/remotes/origin/}" || default="main"
			if [[ -n "$branch" ]]; then
				ahead=$(git -C "$path" rev-list --count "origin/$default..$branch" 2>/dev/null || echo 0)
				behind=$(git -C "$path" rev-list --count "$branch..origin/$default" 2>/dev/null || echo 0)
				status=""
				[[ "$ahead" -gt 0 ]] && status+="↑$ahead "
				[[ "$behind" -gt 0 ]] && status+="↓$behind"
				echo -e "\033[1;32m🌿 Branch:\033[0m $branch ${status:+\033[1;33m[$status]\033[0m}"
			fi

			# Dirty indicator
			if [[ -n $(git -C "$path" status --porcelain 2>/dev/null) ]]; then
				echo -e '\033[1;31m⚠  Uncommitted changes\033[0m'
			fi
			echo

			echo -e '\033[1;33m📊 Status:\033[0m'
			git -C "$path" -c color.status=always status --short --branch 2>/dev/null
			echo

			echo -e '\033[1;35m📜 Recent Commits:\033[0m'
			git -C "$path" log --oneline --graph --date=short --color=always --pretty='format:%C(auto)%cd %h%d %s' -10 2>/dev/null
PREVIEW
		)") || return 0

	if [[ -n "$selected" ]]; then
		local worktree_path
		worktree_path=$(echo "$selected" | awk '{print $1}')
		sesh connect "$worktree_path"
	fi
}

main() {
	case "${1:-}" in
	-h | --help)
		usage
		exit 0
		;;
	add)
		check_git_repo || {
			echo "Error: Not a git repository"
			exit 1
		}
		local branch_name="${2:-}"
		local base_branch=""
		shift 2 2>/dev/null || shift $# 2>/dev/null || true
		while [[ $# -gt 0 ]]; do
			case "$1" in
			--base)
				base_branch="${2:-}"
				shift 2
				;;
			*)
				shift
				;;
			esac
		done
		add_worktree "$branch_name" "$base_branch"
		;;
	remove)
		check_git_repo || {
			echo "Error: Not a git repository"
			exit 1
		}
		remove_worktree "${2:-}" "${3:-}"
		;;
	prune)
		check_git_repo || {
			echo "Error: Not a git repository"
			exit 1
		}
		prune_worktrees
		;;
	list)
		check_git_repo || {
			echo "Error: Not a git repository"
			exit 1
		}
		list_worktrees
		;;
	list-status)
		check_git_repo || {
			echo "Error: Not a git repository"
			exit 1
		}
		list_worktrees_with_status
		;;
	switch)
		check_git_repo || {
			echo "Error: Not a git repository"
			exit 1
		}
		shift
		switch_worktree "$@"
		;;
	"")
		interactive_mode
		;;
	*)
		echo "Error: Unknown command '$1'"
		echo ""
		usage
		exit 1
		;;
	esac
}

main "$@"
