#!/usr/bin/env bash

# Tmux/sesh integration layer over wt (worktrunk)
# wt handles git operations; this script adds sesh/tmux lifecycle and custom fzf UI
# Usage:
#   worktree                         # Interactive UI
#   worktree add <branch>            # Add worktree
#   worktree add <branch> --base <b> # Add worktree from specific base branch
#   worktree remove <path>           # Remove worktree (fails if dirty)
#   worktree remove <path> --force   # Remove worktree discarding uncommitted changes
#   worktree list                    # List worktrees (for scripting)
#   worktree list --status           # List worktrees with status (for fzf UI)
#   worktree switch <branch>         # Connect to worktree (supports wt shortcuts: pr:N, ^, -)
#   worktree switch -c <branch>      # Create worktree and connect

set -euo pipefail

usage() {
	cat <<EOF
Usage: worktree [COMMAND] [ARGS]

Commands:
    (no args)                  Open interactive worktree manager
    add <branch>               Create new worktree for branch
    add <branch> --base <b>    Create worktree from specific base branch
    remove <path>              Remove worktree at path (fails if dirty)
    remove <path> --force      Remove worktree discarding uncommitted changes
    list                       List worktrees (paths only, for scripting)
    list --status              List worktrees with status indicators
    switch <branch>            Connect to worktree (supports wt shortcuts: pr:N, ^, -)
    switch -c <branch>         Create worktree and connect
    -h, --help                 Show this help

Examples:
    worktree
    worktree add feature-login
    worktree add feature-login --base develop
    worktree remove /path/to/worktree
    worktree switch feature-login
    worktree switch pr:123
    worktree switch -c feature-login
EOF
}

check_git_repo() {
	git rev-parse --git-dir >/dev/null 2>&1
}

get_repo_root() {
	wt list --format json | jq -r 'first(.[] | select(.is_main)) | .path'
}

add_worktree() {
	local branch_name="$1"
	local base_branch="${2:-}"

	if [[ -z "$branch_name" ]]; then
		echo "Error: Branch name cannot be empty"
		return 1
	fi

	local args=(switch --no-cd)
	if ! git rev-parse --verify "$branch_name" >/dev/null 2>&1; then
		args+=(--create)
		[[ -n "$base_branch" ]] && args+=(--base "$base_branch")
	fi
	args+=("$branch_name")

	wt "${args[@]}"
}

remove_worktree() {
	local worktree_path force
	worktree_path="$(echo "${1:-}" | xargs)"
	force="${2:-}"

	if [[ -z "$worktree_path" ]]; then
		echo "Error: Worktree path cannot be empty"
		return 1
	fi

	if [[ "$force" != "--force" ]] && [[ -d "$worktree_path" ]]; then
		local dirty
		dirty=$(git -C "$worktree_path" status --porcelain 2>/dev/null || true)
		if [[ -n "$dirty" ]]; then
			echo "Error: Worktree '$worktree_path' has uncommitted changes. Use --force to discard."
			return 1
		fi
	fi

	local target
	target=$(git -C "$worktree_path" branch --show-current 2>/dev/null || echo "")
	[[ -z "$target" ]] && target="$worktree_path"

	local args=(remove --foreground -y)
	[[ "$force" == "--force" ]] && args+=(-f -D)
	args+=("$target")

	if wt "${args[@]}" 2>/dev/null; then
		tmux-clean >/dev/null 2>&1 || true
		return 0
	fi

	echo "Error: Failed to remove worktree '$target'"
	return 1
}

list_worktrees() {
	local json
	json=$(wt -C "$(get_repo_root)" list --format json)

	if [[ "${1:-}" == "--status" ]]; then
		local esc=$'\033'
		echo "$json" | jq -r \
			--arg red "${esc}[31m" \
			--arg yel "${esc}[33m" \
			--arg cyn "${esc}[36m" \
			--arg grn "${esc}[32m" \
			--arg rst "${esc}[0m" '
			(map(.path | length) | max) as $max |
			.[] |
			([$max - (.path | length), 0] | max) as $pad |
			(.working_tree | if (.staged or .modified or .untracked or .deleted or .renamed) then "\($red)*\($rst)" else "" end) as $dirty |
			(.remote.ahead  // 0 | if . > 0 then "\($yel)↑\(.)\($rst)" else "" end) as $ahead |
			(.remote.behind // 0 | if . > 0 then "\($cyn)↓\(.)\($rst)" else "" end) as $behind |
			"\(.path)\(" " * $pad)\t\($yel)\(.commit.short_sha)\($rst)  \($grn)[\(.branch // "detached")]\($rst) \($dirty)\($ahead)\($behind)"
		'
	else
		echo "$json" | jq -r '.[].path'
	fi
}

switch_worktree() {
	local create=0
	local branch_name=""
	local base_branch=""
	while [[ $# -gt 0 ]]; do
		case "$1" in
		-c) create=1; shift ;;
		--base) base_branch="${2:-}"; shift 2 ;;
		*) branch_name="$1"; shift ;;
		esac
	done

	if [[ -z "$branch_name" ]]; then
		echo "Error: Branch name required"
		return 1
	fi

	local args=(switch --no-cd -x "sesh connect {{ worktree_path }}")
	[[ "$create" -eq 1 ]] && args+=(--create)
	[[ -n "$base_branch" ]] && args+=(--base "$base_branch")
	args+=("$branch_name")

	wt "${args[@]}"
}

interactive_mode() {
	if ! check_git_repo; then
		return 1
	fi

	local repo_root
	repo_root=$(get_repo_root)

	local selected
	selected=$(worktree -C "$repo_root" list --status | fzf \
		--ansi \
		--delimiter $'\t' \
		--border-label '🌴 Worktrees ' \
		--header 'CTRL-X (remove) : CTRL-A (add) : ENTER (connect)' \
		--bind "ctrl-x:execute-silent(worktree -C '$repo_root' remove {1} --force 2>/dev/null || true)+reload(worktree -C '$repo_root' list --status)" \
		--bind "ctrl-a:transform:[[ -n {q} ]] && echo 'reload(worktree -C \"$repo_root\" add {q} --base main >/dev/null; worktree -C \"$repo_root\" list --status)' || echo 'bell'" \
		--preview "$(
			cat <<'PREVIEW'
			path=$(echo {1} | xargs)
			echo -e '\033[1;36m📍 Worktree:\033[0m '"$path"
			echo

			branch=$(git -C "$path" branch --show-current 2>/dev/null)
			ref=$(git -C "$path" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null) && default="${ref##refs/remotes/origin/}" || default="main"
			if [[ -n "$branch" ]]; then
				ahead=$(git -C "$path" rev-list --count "origin/$default..$branch" 2>/dev/null || echo 0)
				behind=$(git -C "$path" rev-list --count "$branch..origin/$default" 2>/dev/null || echo 0)
				status=""
				[[ "$ahead" -gt 0 ]] && status+="↑$ahead "
				[[ "$behind" -gt 0 ]] && status+="↓$behind"
				echo -e "\033[1;32m🌿 Branch:\033[0m $branch ${status:+\033[1;33m[$status]\033[0m}"
			fi

			if [[ -n $(git -C "$path" status --porcelain 2>/dev/null) ]]; then
				echo -e '\033[1;31m⚠  Uncommitted changes\033[0m'
			fi
			echo

			echo -e '\033[1;33m📊 Status:\033[0m'
			git -C "$path" -c color.status=always status --short --branch 2>/dev/null
			echo

			echo -e '\033[1;35m📜 Recent Commits:\033[0m'
			git -C "$path" log --oneline --graph --date=short --color=always --pretty='format:%C(auto)%cd %h%d %s' -10 2>/dev/null
PREVIEW
		)") || return 0

	if [[ -n "$selected" ]]; then
		local worktree_path
		worktree_path=$(echo "$selected" | cut -f1 | xargs)
		sesh connect "$worktree_path"
	fi
}

main() {
	if [[ "${1:-}" == "-C" ]]; then
		cd "${2:?}" 2>/dev/null || true
		shift 2
	fi

	case "${1:-}" in
	-h | --help)
		usage
		exit 0
		;;
	add)
		check_git_repo || { echo "Error: Not a git repository"; exit 1; }
		local branch_name="${2:-}"
		local base_branch=""
		shift 2 2>/dev/null || shift $# 2>/dev/null || true
		while [[ $# -gt 0 ]]; do
			case "$1" in
			--base) base_branch="${2:-}"; shift 2 ;;
			*) shift ;;
			esac
		done
		add_worktree "$branch_name" "$base_branch"
		;;
	remove)
		check_git_repo || { echo "Error: Not a git repository"; exit 1; }
		remove_worktree "${2:-}" "${3:-}"
		;;
	list)
		check_git_repo || { echo "Error: Not a git repository"; exit 1; }
		list_worktrees "${2:-}"
		;;
	switch)
		check_git_repo || { echo "Error: Not a git repository"; exit 1; }
		shift
		switch_worktree "$@"
		;;
	"")
		interactive_mode
		;;
	*)
		echo "Error: Unknown command '$1'"
		echo ""
		usage
		exit 1
		;;
	esac
}

main "$@"
