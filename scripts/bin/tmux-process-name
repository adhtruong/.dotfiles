#!/usr/bin/env bash

# Returns the display name for a tmux pane, detecting AI agents by process tree

pane_pid="$1"
window_name="$2"

result=$(ps -axo ppid,comm | awk -v ppid="$pane_pid" '
  $1 == ppid && $2 ~ /\/agent$/ {print "cursor"; exit}
  $1 == ppid && $2 == "claude" {print "claude"; exit}
')

echo "${result:-$window_name}"
