#!/usr/bin/env bash

set -euo pipefail

selected="$(
	sesh list --icons -d | fzf \
		--ansi \
		--no-sort --border-label ' sesh ' --prompt '⚡  ' \
		--header '^a all ^t tmux ^x zoxide ^d kill ^f find ^w worktrees' \
		--preview 'sesh preview {}' \
		--preview-window='right:50%' \
		--bind 'tab:down,btab:up' \
		--bind 'ctrl-a:change-prompt(⚡  )+reload(sesh list --icons)' \
		--bind 'ctrl-t:change-prompt(🪟  )+reload(sesh list -t --icons)' \
		--bind 'ctrl-x:change-prompt(📁  )+reload(sesh list -z --icons)' \
		--bind 'ctrl-f:change-prompt(🔎  )+reload(fd -H -d 2 -t d -E .Trash . ~)' \
		--bind 'ctrl-w:become(worktree)' \
		--bind 'ctrl-d:execute(tmux kill-session -t {2..})+change-prompt(⚡  )+reload(sesh list --icons -d)' \
		|| true
)"
if [[ -n "$selected" ]]; then sesh connect "$selected"; fi
